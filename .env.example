# Referência raiz. As variáveis efetivas moram em backend/.env e frontend/.env.local
# (o Prisma lê backend/.env; o Next lê frontend/.env.local). Ver READMEs.

# --- Banco (backend) ---
# Docker (docker-compose.yml):
#   DATABASE_URL="postgresql://wefans:wefans@localhost:5432/wefans?schema=public"
# Postgres local (macOS/Homebrew, trust auth pelo usuário do SO):
#   DATABASE_URL="postgresql://SEU_USUARIO@localhost:5432/wefans?schema=public"

# --- Frontend ---
# API_BASE_URL="http://localhost:4000"          # usado no server (SSR)
# NEXT_PUBLIC_API_URL="http://localhost:4000"    # usado no browser
