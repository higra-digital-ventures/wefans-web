# Conexão do Prisma/Fastify com o Postgres.
# Docker (docker-compose.yml):
#   DATABASE_URL="postgresql://wefans:wefans@localhost:5432/wefans?schema=public"
# Postgres local (macOS/Homebrew, trust auth pelo usuário do SO):
DATABASE_URL="postgresql://USER@localhost:5432/wefans?schema=public"

PORT=4000
NODE_ENV=development

# Origem permitida no CORS (frontend web)
CORS_ORIGIN=http://localhost:3000
