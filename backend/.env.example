# Conexão do Prisma/Fastify com o Postgres.
# Docker (docker-compose.yml):
#   DATABASE_URL="postgresql://wefans:wefans@localhost:5432/wefans?schema=public"
# Postgres local (macOS/Homebrew, trust auth pelo usuário do SO):
# connection_limit/pool_timeout ajudam sob concorrência (ex.: abrir vários pacotes ao mesmo tempo).
DATABASE_URL="postgresql://USER@localhost:5432/wefans?schema=public&connection_limit=20&pool_timeout=20"

PORT=4000
NODE_ENV=development

# Origem permitida no CORS (frontend web)
CORS_ORIGIN=http://localhost:3000

# Auth (Fase 1) — troque os segredos em produção (>= 16 chars)
JWT_ACCESS_SECRET="troque-por-um-segredo-forte-de-acesso"
JWT_SESSION_SECRET="troque-por-um-segredo-forte-de-sessao"
ACCESS_TOKEN_TTL=15m
SESSION_TOKEN_TTL=7d
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_NAME=wf_session
