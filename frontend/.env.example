# URL do backend usada no servidor (SSR / server components)
# 127.0.0.1 (e não localhost): no Windows o Node tenta IPv6 (::1) primeiro e
# paga ~200ms de fallback POR CHAMADA — a API só escuta IPv4.
API_BASE_URL=http://127.0.0.1:4000
# URL do backend exposta ao browser (chamadas client-side)
NEXT_PUBLIC_API_URL=http://localhost:4000
